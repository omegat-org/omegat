    <segment_properties_notify_props>hasComment, hasNote</segment_properties_notify_props>
    <segment_properties_show_raw_keys>false</segment_properties_show_raw_keys>
    <source_lang>en</source_lang>
    <target_lang>fr</target_lang>
    <tagValidateOnLeave>true</tagValidateOnLeave>
