    <dictionary_fuzzy_matching>false</dictionary_fuzzy_matching>
    <dictionary_use_font>true</dictionary_use_font>
    <display_modification_info>selected</display_modification_info>
    <editor_initial_segment_load_count>2000</editor_initial_segment_load_count>
    <ext_tmx_fuzzy_match_threshold>30</ext_tmx_fuzzy_match_threshold>
    <ext_tmx_match_template>${id}. ${fuzzyFlag}${sourceText}
${targetText}
&lt;${score}/${noStemScore}/${adjustedScore}% ${filePath}></ext_tmx_match_template>
    <ext_tmx_show_level2>false</ext_tmx_show_level2>
    <ext_tmx_sort_key>SCORE</ext_tmx_sort_key>
    <ext_tmx_use_slash>false</ext_tmx_use_slash>
    <external_command></external_command>
    <external_finder_allow_project_commands>false</external_finder_allow_project_commands>
    <glossary_layout>org.omegat.gui.glossary.DefaultGlossaryRenderer</glossary_layout>
    <glossary_merge_alternate_definitions>true</glossary_merge_alternate_definitions>
    <glossary_not_exact_match>true</glossary_not_exact_match>
    <glossary_replace_on_insert>false</glossary_replace_on_insert>
    <glossary_require_similar_case>true</glossary_require_similar_case>
    <glossary_sort_by_length>false</glossary_sort_by_length>
    <glossary_sort_by_src_length>false</glossary_sort_by_src_length>
    <glossary_stemming>false</glossary_stemming>
    <glossary_tbx_display_context>false</glossary_tbx_display_context>
    <history_completer_prediction_enabled>true</history_completer_prediction_enabled>
    <issue_providers_disabled></issue_providers_disabled>
    <issue_providers_dont_ask>false</issue_providers_dont_ask>
    <issues_window_divider_location_bottom>396</issues_window_divider_location_bottom>
