<?xml version='1.0' encoding='UTF-8'?>
<omegat>
  <preference version="1.0">
    <ac_autotext_enabled>false</ac_autotext_enabled>
    <ac_chartable_enabled>true</ac_chartable_enabled>
    <ac_glossary_enabled>true</ac_glossary_enabled>
    <ac_glossary_show_source>false</ac_glossary_show_source>
    <ac_glossary_sort_alphabetically>false</ac_glossary_sort_alphabetically>
    <ac_glossary_sort_by_length>false</ac_glossary_sort_by_length>
    <ac_show_suggestions_automatically>false</ac_show_suggestions_automatically>
    <ac_switch_views_with_lr>false</ac_switch_views_with_lr>
    <allowTagEditing>false</allowTagEditing>
    <always_confirm_quit>false</always_confirm_quit>
    <auto_save_interval>180</auto_save_interval>
    <automatically_check_version>true</automatically_check_version>
    <create_glossary_dialog_height>270</create_glossary_dialog_height>
    <create_glossary_dialog_width>373</create_glossary_dialog_width>
    <create_glossary_dialog_x>53</create_glossary_dialog_x>
    <create_glossary_dialog_y>29</create_glossary_dialog_y>
    <dictionary_auto_search>true</dictionary_auto_search>
    <dictionary_condensed_view>false</dictionary_condensed_view>
