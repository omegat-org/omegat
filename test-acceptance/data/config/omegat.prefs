    <tagValidation_elaborateCheck>false</tagValidation_elaborateCheck>
    <tagValidation_javaMessageFormatSimplePatternCheck>false</tagValidation_javaMessageFormatSimplePatternCheck>
    <tagValidation_noCheck>true</tagValidation_noCheck>
    <tagValidation_removePattern></tagValidation_removePattern>
    <tagValidation_simpleCheck>false</tagValidation_simpleCheck>
    <tags_valid_required>false</tags_valid_required>
    <view_option_mod_info_template>${creationId} - ${changedId} ${changedDate} ${changedTime}</view_option_mod_info_template>
    <view_option_mod_info_template_wo_date>${creationId} - ${changedId}</view_option_mod_info_template_wo_date>
