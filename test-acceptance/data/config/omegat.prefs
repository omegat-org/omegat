    <issues_window_width>956</issues_window_width>
    <issues_window_x>327</issues_window_x>
    <issues_window_y>204</issues_window_y>
    <keep_foreign_matches>false</keep_foreign_matches>
    <loose_tag_ordering>false</loose_tag_ordering>
    <mark_autopopulated>true</mark_autopopulated>
    <mark_non_unique_segments>true</mark_non_unique_segments>
    <mark_para_delimitation>true</mark_para_delimitation>
    <mark_para_delimitation_text>— ¶ —————————————————————</mark_para_delimitation_text>
    <mt_auto_fetch>true</mt_auto_fetch>
    <mt_only_untranslated>false</mt_only_untranslated>
